easyblock = 'EcbuildMake'

name = 'bufrdc_emoslib'
version = '4.6.7'

homepage = ' ... '
description = """I don't know ..."""

toolchain = {'name': 'iimpi', 'version': '2024a'}

sources = [{
    'filename': 'bufrdc_emoslib.tar.gz',
    'git_config': {
        'url': 'ssh://git@git.ecmwf.int/mars',
        'repo_name': 'bufrdc_emoslib',
        'tag': '%(version)s',
